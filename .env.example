ZENDESK_SUBDOMAIN=
ZENDESK_EMAIL=
ZENDESK_API_TOKEN=
DD_API_KEY=
DD_APP_KEY=
DD_SITE=datadoghq.com
DD_CALL_CENTER_TAG=@log.machineData.callCenterName
DD_STATION_TAG=@log.machineData.name
# LLM_PROVIDER values: unleash (HTTP, default) | codex (Codex CLI)
LLM_PROVIDER=unleash
UNLEASH_API_KEY=
UNLEASH_BASE_URL=https://e-api.unleash.so
UNLEASH_ASSISTANT_ID=
UNLEASH_ACCOUNT=
# When LLM_PROVIDER=codex: app-server (persistent JSON-RPC) | exec (subprocess only)
# setup writes exec if app-server probe fails; use exec in CI without a Codex seat
CODEX_TRANSPORT=app-server
# Structured complete() routing: auto | exec | app-server.
# Safe default: auto currently stays on exec until app-server parity evidence is accepted.
CODEX_COMPLETE_TRANSPORT=auto
CODEX_MODEL=gpt-5.5
